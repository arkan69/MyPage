---
const links = [
  { href: '#services', label: 'Services' },
  { href: '#projects', label: 'Projects' },
  { href: '#about', label: 'About' },
  { href: '#tech-stack', label: 'Tech Stack' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 border-b border-zinc-800/80 bg-zinc-950/75 backdrop-blur-md">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="#" class="text-sm font-semibold uppercase tracking-[0.28em] text-zinc-100">
      Arkansyah
    </a>

    <div class="hidden items-center gap-6 md:flex">
      {links.map((link) => (
        <a href={link.href} class="text-sm text-zinc-400 transition hover:text-zinc-100">
          {link.label}
        </a>
      ))}
    </div>

    <a
      href="#contact"
      class="rounded-lg border border-blue-500/35 bg-blue-500/8 px-4 py-2 text-sm font-medium text-blue-300 transition hover:border-blue-400 hover:bg-blue-500/15 hover:text-zinc-100"
    >
      Let&apos;s Talk
    </a>
  </nav>
</header>
